-- Автоматический поиск модема с любой стороны компьютера
local modem = peripheral.find("modem")

-- Проверяем, удалось ли найти модем
if not modem then
    print("Error: Modem not found! Please attach a modem.")
    return
end

-- Получаем системное имя стороны, где стоит модем (нужно для Rednet)
local modemSide = peripheral.getName(modem)

term.clear()
term.setCursorPos(1, 1)
print("=== Receiver Setup ===")

-- Ввод канала вручную с проверкой
local CHANNEL
while true do
    write("Enter modem channel to listen (1-65535): ")
    local input = read()
    local num = tonumber(input)
    if num and num >= 1 and num <= 65535 then
        CHANNEL = num
        break
    else
        print("Invalid channel! Please enter a number between 1 and 65535.")
    end
end

-- Открываем обычный канал на модеме
modem.open(CHANNEL)

-- Открываем Rednet поверх этого же модема
rednet.open(modemSide)

term.clear()
term.setCursorPos(1, 1)
print("=== Universal Wireless Receiver ===")
print("Your Computer ID: " .. os.getComputerID())
print("Listening on Modem Channel: " .. CHANNEL)
print("Listening on Rednet: ENABLED")
print("Press 'Ctrl+T' to exit.\n")
print("Waiting for messages...")

-- Вспомогательная функция для красивого вывода сообщений
local function displayMessage(sourceType, sender, distance, message)
    print("\n-----------------------------------")
    print("[" .. sourceType .. "] Сообщение")
    print("Отправитель: " .. sender)
    if distance then
        print("Расстояние:  " .. distance .. " блоков")
    else
        print("Расстояние:  Неизвестно (через Rednet)")
    end
    
    -- Вывод самого сообщения
    if type(message) == "table" then
        print("Сообщение:   " .. textutils.serialize(message))
    else
        print("Сообщение:   " .. tostring(message))
    end
end

-- Главный цикл ожидания сообщений
while true do
    -- Перехватываем любые события в системе
    local event, p1, p2, p3, p4, p5 = os.pullEvent()
    
    -- 1. Если пришло сообщение через обычный модем
    if event == "modem_message" then
        local side, channel, replyChannel, message, distance = p1, p2, p3, p4, p5
        
        -- Проверяем, что сообщение пришло именно на наш выбранный канал
        if channel == CHANNEL then
            -- Используем replyChannel в качестве примерного "имени" отправителя
            local senderName = replyChannel and ("Канал " .. replyChannel) or "Неизвестный канал"
            
            displayMessage("MODEM", senderName, distance, message)
            
            -- Авто-ответ отправителю
            if replyChannel then
                modem.transmit(replyChannel, CHANNEL, "ACK: Modem message received!")
            end
        end
        
    -- 2. Если пришло сообщение через систему Rednet
    elseif event == "rednet_message" then
        local senderID, message, protocol = p1, p2, p3
        
        -- Rednet API скрывает параметр distance внутри своего протокола передачи, 
        -- но мы выводим его как "Неизвестно" или определяем через ID отправителя.
        local senderName = "Компьютер #" .. senderID
        if protocol then
            senderName = senderName .. " (Протокол: " .. tostring(protocol) .. ")"
        end
        
        displayMessage("REDNET", senderName, nil, message)
    end
end
