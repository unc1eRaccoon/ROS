-- Automatically look up a modem on any side of the computer
local modem = peripheral.find("modem")

-- Check if a modem was successfully found
if not modem then
    print("Error: Modem not found! Please attach a modem.")
    return
end

-- Get the system name of the side where the modem is attached (required for Rednet)
local modemSide = peripheral.getName(modem)

term.clear()
term.setCursorPos(1, 1)
print("=== Receiver Setup ===")

-- Manual channel input with validation loop
local CHANNEL
while true do
    write("Enter modem channel to listen (1-65535): ")
    local input = read()
    local num = tonumber(input)
    if num and num >= 1 and num <= 65535 then
        CHANNEL = num
        break
    else
        print("Invalid channel! Please enter a number between 1 and 65535.")
    end
end

-- Open the specified channel on the raw modem
modem.open(CHANNEL)

-- Open the Rednet API over the exact same modem side
rednet.open(modemSide)

term.clear()
term.setCursorPos(1, 1)
print("=== Universal Wireless Receiver ===")
print("Your Computer ID: " .. os.getComputerID())
print("Listening on Modem Channel: " .. CHANNEL)
print("Listening on Rednet: ENABLED")
print("Press 'Ctrl+T' to exit.\n")
print("Waiting for messages...")

-- Helper function for clean message formatting and output
local function displayMessage(sourceType, sender, distance, message)
    print("\n-----------------------------------")
    print("[" .. sourceType .. "] Message incoming")
    print("Sender:   " .. sender)
    if distance then
        print("Distance: " .. distance .. " blocks")
    else
        print("Distance: Unknown (via Rednet)")
    end
    
    -- Format and print the message body based on its type
    if type(message) == "table" then
        print("Message:  " .. textutils.serialize(message))
    else
        print("Message:  " .. tostring(message))
    end
end

-- Main event polling loop
while true do
    -- Intercept any events triggered within the system
    local event, p1, p2, p3, p4, p5 = os.pullEvent()
    
    -- 1. Handle incoming raw modem transmission
    if event == "modem_message" then
        local side, channel, replyChannel, message, distance = p1, p2, p3, p4, p5
        
        -- Double check that the packet matches our configured channel
        if channel == CHANNEL then
            -- Fallback to reply channel description as sender name identifier
            local senderName = replyChannel and ("Channel " .. replyChannel) or "Unknown Channel"
            
            displayMessage("MODEM", senderName, distance, message)
            
            -- Automatically respond back to sender if they provided a reply channel
            if replyChannel then
                modem.transmit(replyChannel, CHANNEL, "ACK: Modem message received!")
            end
        end
        
    -- 2. Handle incoming high-level Rednet system transmission
    elseif event == "rednet_message" then
        local senderID, message, protocol = p1, p2, p3
        
        -- Formulate sender details based on computer ID and potential protocol
        local senderName = "Computer #" .. senderID
        if protocol then
            senderName = senderName .. " (Protocol: " .. tostring(protocol) .. ")"
        end
        
        displayMessage("REDNET", senderName, nil, message)
    end
end
